generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id Int @id @default(autoincrement())

  name String

  // Company profile / branding — surfaced via GET/PUT /company/settings and
  // used downstream for email templates, PDFs, quotes, and invoices.
  logoUrl      String?
  billingEmail String?
  contactEmail String?
  phone        String?
  website      String?
  address      String?
  taxNumber    String?
  vatNumber    String?

  // Subscription / billing — Stripe Checkout + webhook keep these in sync.
  plan                 String    @default("free")
  subscriptionStatus   String    @default("inactive")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionEndsAt   DateTime?

  // Soft-delete — set together when the owning BUSINESS_OWNER deletes their
  // account. Existing rows/relations are kept for history, nothing is
  // physically removed.
  active    Boolean   @default(true)
  deletedAt DateTime?

  employees   Employee[]
  customers   Customer[]
  projects    Project[]
  users       User[]
  invitations Invitation[]
  auditLogs   AuditLog[]
  ownerNotes  OwnerNote[]

  // Phase 3 — Owner Command Center conversion targets.
  tasks               Task[]
  reminders           Reminder[]
  communicationLogs   CommunicationLog[]
  projectInternalNotes ProjectInternalNote[]
  ownerNoteConversions OwnerNoteConversion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id Int @id @default(autoincrement())

  email    String @unique
  password String
  role     String @default("BUSINESS_OWNER")

  emailVerified               Boolean   @default(false)
  emailVerificationToken      String?   @unique
  emailVerificationExpiresAt  DateTime?

  passwordResetToken      String?   @unique
  passwordResetExpiresAt  DateTime?

  // Soft-delete — login is rejected once `active` is false. Set by
  // POST /account/delete; nothing is physically removed.
  active    Boolean   @default(true)
  deletedAt DateTime?

  // Optional: a DEVELOPER (platform operator) belongs to no company.
  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id])

  // Set only for EMPLOYEE-role users — links the login to the worker record
  // that owns their shifts/projects.
  employeeId Int?     @unique
  employee   Employee? @relation(fields: [employeeId], references: [id])

  projectNotes         ProjectNote[]
  projectAttachments   ProjectAttachment[]
  projectActivities    ProjectActivity[]
  ownerNotes           OwnerNote[]
  projectInternalNotes ProjectInternalNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id Int @id @default(autoincrement())

  firstName String
  lastName  String
  phone     String?
  email     String?

  status String @default("Active")

  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id])

  assignments ProjectAssignment[]
  user        User?
  ownerNotes  OwnerNote[]
  tasks       Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Shift     Shift[]
}

model Project {
  id Int @id @default(autoincrement())

  name        String
  description String?
  status      String    @default("Planned")
  deadline    DateTime?

  // Geofence foundation (V1) — location data only, no automatic clock
  // in/out is wired up to this yet.
  address          String?
  latitude         Float?
  longitude        Float?
  geofenceRadius   Float?
  geofenceEnabled  Boolean @default(false)

  customerId Int?

  customer Customer? @relation(fields: [customerId], references: [id])

  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id])

  assignments ProjectAssignment[]
  notes       ProjectNote[]
  attachments ProjectAttachment[]
  activities  ProjectActivity[]
  ownerNotes  OwnerNote[]

  // Phase 3 — Owner Command Center conversion targets.
  tasks             Task[]
  reminders         Reminder[]
  communicationLogs CommunicationLog[]
  internalNotes     ProjectInternalNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Shift     Shift[]
}

model ProjectNote {
  id Int @id @default(autoincrement())

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  content String

  createdAt DateTime @default(now())
}

model ProjectAttachment {
  id Int @id @default(autoincrement())

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  fileName String
  fileType String
  fileSize Int
  fileUrl  String

  // Free-form on purpose (not a Prisma enum) so adding a category later is
  // a data change, not a migration. Validated against a fixed list at the
  // API layer (see constants/attachmentCategories.ts) — defaults to
  // "Other" for both new uploads without a category and existing rows.
  category String @default("Other")

  createdAt DateTime @default(now())
}

// Free-form, append-only feed of everything that happens on a project — the
// "what happened, when, who did it" timeline shown in Project Details.
// `metadata` is a free-form JSON string (same approach as AuditLog) since
// each `type` carries different shape (e.g. FILE_UPLOADED carries a file
// name, CLOCK_OUT carries nothing extra).
model ProjectActivity {
  id Int @id @default(autoincrement())

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  type     String
  metadata String?

  createdAt DateTime @default(now())
}

model ProjectAssignment {
  id Int @id @default(autoincrement())

  employeeId Int
  projectId  Int

  employee Employee @relation(fields: [employeeId], references: [id])

  project Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())

  @@unique([employeeId, projectId])
}

model Customer {
  id Int @id @default(autoincrement())

  name    String
  email   String?
  phone   String?
  address String?

  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id])

  projects   Project[]
  ownerNotes OwnerNote[]

  // Phase 3 — Owner Command Center conversion targets.
  reminders         Reminder[]
  communicationLogs CommunicationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shift {
  id Int @id @default(autoincrement())

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])

  start DateTime
  end   DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Owner Command Center — a private, owner-only scratchpad for quick notes
// and reminders, optionally linked to a Project/Customer for context.
// Deliberately separate from ProjectNote (which is project-scoped and
// visible to assigned employees too); these are owner/developer-only.
model OwnerNote {
  id Int @id @default(autoincrement())

  title   String
  content String

  // "Inbox" | "Reviewed" | "ReadyToConvert" | "Archived" — see
  // constants/ownerNoteStatuses.ts. Free-form on purpose, same rationale as
  // ProjectAttachment.category.
  status String @default("Inbox")

  // Phase 3 — "Low" | "Medium" | "High" | "Urgent", see constants/priorities.ts.
  // Free-form for the same reason as `status`. Transfers to Task/Reminder
  // when a note is converted.
  priority String @default("Medium")

  // Phase 3 — pinned notes always sort first, ignoring normal ordering.
  pinned Boolean @default(false)

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Phase 2 — owner can also link the note to the employee it's about
  // (e.g. "Peter should go on Friday"). Detection only ever suggests this;
  // linking always requires an explicit owner action.
  employeeId Int?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  // Phase 3 — every conversion this note has produced (Task, Reminder,
  // CommunicationLog, ProjectInternalNote). Used for duplicate-protection
  // ("already converted") display and audit history.
  conversions OwnerNoteConversion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Phase 3 — minimum Task architecture needed for Owner Command Center
// conversions. Deliberately not a full task-management module (no
// checklists, no templates, no sub-tasks) — see OwnerNote conversion flow
// in ownerNotes.routes.ts. Designed to be extended later without breaking
// this shape.
model Task {
  id Int @id @default(autoincrement())

  title       String
  description String?

  // "Open" | "InProgress" | "Done" — see constants/taskStatuses.ts.
  status String @default("Open")

  // "Low" | "Medium" | "High" | "Urgent" — see constants/priorities.ts.
  priority String @default("Medium")

  dueDate DateTime?

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])

  employeeId Int?
  employee   Employee? @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Phase 3 — Owner Note → Reminder conversion target. Notification delivery
// (push/PWA) is a future extension point; this only stores the reminder
// itself.
model Reminder {
  id Int @id @default(autoincrement())

  title   String
  dueDate DateTime?

  // "Low" | "Medium" | "High" | "Urgent" — see constants/priorities.ts.
  priority String @default("Medium")

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Phase 3 — Owner Note → Communication Log conversion target. Records a
// customer interaction (call/email/meeting) the owner logged from a note.
model CommunicationLog {
  id Int @id @default(autoincrement())

  // "PhoneCall" | "Email" | "Meeting" | "Other" — see
  // constants/communicationTypes.ts.
  type    String @default("Other")
  content String

  occurredAt DateTime @default(now())

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
}

// Phase 3 — Owner Note → Project Internal Note conversion target.
// Deliberately separate from ProjectNote: ProjectNote is visible to
// assigned employees, this is owner/developer-only (same visibility rule
// as OwnerNote itself).
model ProjectInternalNote {
  id Int @id @default(autoincrement())

  content String

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// Phase 3 — audit trail of every conversion an OwnerNote has produced.
// `targetType` + `targetId` point at the created Task/Reminder/
// CommunicationLog/ProjectInternalNote row. Drives duplicate-protection
// ("already converted") checks and the conversion history view.
model OwnerNoteConversion {
  id Int @id @default(autoincrement())

  ownerNoteId Int
  ownerNote   OwnerNote @relation(fields: [ownerNoteId], references: [id])

  // "Task" | "Reminder" | "CommunicationLog" | "ProjectInternalNote"
  targetType String
  targetId   Int

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
}

model AuditLog {
  id Int @id @default(autoincrement())

  action String

  userId    Int?
  companyId Int?
  company   Company? @relation(fields: [companyId], references: [id])

  // Free-form JSON string — kept simple (no separate key/value table) since
  // this is a fixed-shape audit trail, not a queryable analytics store.
  metadata String?

  createdAt DateTime @default(now())
}

model Invitation {
  id Int @id @default(autoincrement())

  email String
  token String @unique
  role  String @default("EMPLOYEE")

  companyId Int
  company   Company @relation(fields: [companyId], references: [id])

  invitedByUserId Int

  expiresAt  DateTime
  acceptedAt DateTime?

  createdAt DateTime @default(now())
}
